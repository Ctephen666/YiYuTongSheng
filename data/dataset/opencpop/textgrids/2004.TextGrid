	item [1]:
		class = "IntervalTier"
		name = "句子"
		xmin = 0.0
		xmax = 237.35379
		intervals: size = 38
			intervals [1]:
				xmin = 0.0
				xmax = 6.88957
				text = "silence"
			intervals [2]:
				xmin = 6.88957
				xmax = 11.61354
				text = "silence"
			intervals [3]:
				xmin = 11.61354
				xmax = 16.83889
				text = "silence"
			intervals [4]:
				xmin = 16.83889
				xmax = 23.34162
				text = "一张照片半句再见尘封的纪念"
			intervals [5]:
				xmin = 23.34162
				xmax = 29.18343
				text = "用眼泪把你复习一遍"
			intervals [6]:
				xmin = 29.18343
				xmax = 36.32019
				text = "残缺的诗篇遗忘的誓言"
			intervals [7]:
				xmin = 36.32019
				xmax = 43.62721
				text = "谁脑海有张忘不掉的脸"
			intervals [8]:
				xmin = 43.62721
				xmax = 50.21066
				text = "微红的眼微亮的天好一次失眠"
			intervals [9]:
				xmin = 50.21066
				xmax = 55.99732
				text = "回忆轻易带走了时间"
			intervals [10]:
				xmin = 55.99732
				xmax = 63.97761
				text = "有些从前太执念那痕迹太明显"
			intervals [11]:
				xmin = 63.97761
				xmax = 69.96206
				text = "而故事被遗憾画上了终点"
			intervals [12]:
				xmin = 69.96206
				xmax = 76.46928
				text = "为何不放既是过往云烟"
			intervals [13]:
				xmin = 76.46928
				xmax = 83.38902
				text = "想要遗忘怎么反复挂牵"
			intervals [14]:
				xmin = 83.38902
				xmax = 89.90569
				text = "往哪里找安慰会简单一些"
			intervals [15]:
				xmin = 89.90569
				xmax = 96.23755
				text = "我被思念制约快乐显得卑微"
			intervals [16]:
				xmin = 96.23755
				xmax = 102.81775
				text = "怎么不放早是过往云烟"
			intervals [17]:
				xmin = 102.81775
				xmax = 109.65986
				text = "越想遗忘越是反复挂牵"
			intervals [18]:
				xmin = 109.65986
				xmax = 116.16303
				text = "而你在心里面要怎么道别"
			intervals [19]:
				xmin = 116.16303
				xmax = 123.26009
				text = "说这半句再见已过了多少年"
			intervals [20]:
				xmin = 123.26009
				xmax = 126.35507
				text = "无解"
			intervals [21]:
				xmin = 126.35507
				xmax = 130.61283
				text = "silence"
			intervals [22]:
				xmin = 130.61283
				xmax = 135.912
				text = "silence"
			intervals [23]:
				xmin = 135.912
				xmax = 142.64675
				text = "一段在彼一段在天两端成直线"
			intervals [24]:
				xmin = 142.64675
				xmax = 148.46984
				text = "直线永远画不出个圈"
			intervals [25]:
				xmin = 148.46984
				xmax = 156.19034
				text = "有些从前太尖锐谁脚步太遥远"
			intervals [26]:
