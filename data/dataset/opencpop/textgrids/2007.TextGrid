			intervals [4]:
				xmin = 18.28381
				xmax = 25.81756
				text = "我问为什么那女孩传简讯给我"
			intervals [5]:
				xmin = 25.81756
				xmax = 32.37262
				text = "而你为什么不解释低着头沉默"
			intervals [6]:
				xmin = 32.37262
				xmax = 36.25233
				text = "我该相信你很爱我"
			intervals [7]:
				xmin = 36.25233
				xmax = 39.69629
				text = "不愿意敷衍我"
			intervals [8]:
				xmin = 39.69629
				xmax = 42.04313
				text = "还是明白你已"
			intervals [9]:
				xmin = 42.04313
				xmax = 48.78705
				text = "不想挽回什么"
			intervals [10]:
				xmin = 48.78705
				xmax = 51.05321
				text = "想问为什么"
			intervals [11]:
				xmin = 51.05321
				xmax = 56.3793
				text = "我不再是你的快乐"
			intervals [12]:
				xmin = 56.3793
				xmax = 62.75536
				text = "可是为什么却苦笑说我都懂了
"
			intervals [13]:
				xmin = 62.75536
				xmax = 66.67915
				text = "自尊常常将人拖着"
			intervals [14]:
				xmin = 66.67915
				xmax = 70.12911
				text = "把爱都走曲折"
			intervals [15]:
				xmin = 70.12911
				xmax = 76.12633
				text = "假装了解是怕真相太赤裸裸"
			intervals [16]:
				xmin = 76.12633
				xmax = 79.53917
				text = "狼狈比失去难受"
			intervals [17]:
				xmin = 79.53917
				xmax = 83.26807
				text = "我怀念的是无话不说"
			intervals [18]:
				xmin = 83.26807
