			intervals [6]:
				xmin = 32.98135
				xmax = 36.41664
				text = "为你我用了半年的积蓄"
			intervals [7]:
				xmin = 36.41664
				xmax = 40.82284
				text = "漂洋过海的来看你"
			intervals [8]:
				xmin = 40.82284
				xmax = 42.66621
				text = "为了这次相聚"
			intervals [9]:
				xmin = 42.66621
				xmax = 48.68628
				text = "我连见面时的呼吸都曾反复练习"
			intervals [10]:
				xmin = 48.68628
				xmax = 52.18883
				text = "言语从来没能将我的情意"
			intervals [11]:
				xmin = 52.18883
				xmax = 56.54144
				text = "表达千万分之一"
			intervals [12]:
				xmin = 56.54144
				xmax = 60.61423
				text = "为了这个遗憾我在夜里想了又想"
			intervals [13]:
				xmin = 60.61423
				xmax = 64.35397
				text = "不肯睡去"
			intervals [14]:
				xmin = 64.35397
				xmax = 72.28722
				text = "记忆它总是慢慢的累积在我心中无法抹去"
			intervals [15]:
				xmin = 72.28722
				xmax = 76.35227
				text = "为了你的承诺我在最绝望的时候"
			intervals [16]:
				xmin = 76.35227
				xmax = 82.04565
				text = "都忍着不哭泣"
			intervals [17]:
				xmin = 82.04565
				xmax = 85.96414
				text = "陌生的城市啊"
			intervals [18]:
				xmin = 85.96414
