				xmax = 19.72163
				text = "silence"
			intervals [4]:
				xmin = 19.72163
				xmax = 24.25957
				text = "突然发现站了好久"
			intervals [5]:
				xmin = 24.25957
				xmax = 28.53593
				text = "不知道要往哪走"
			intervals [6]:
				xmin = 28.53593
				xmax = 32.50792
				text = "还不想回家的我"
			intervals [7]:
				xmin = 32.50792
				xmax = 36.70599
				text = "再多人陪只会更寂寞"
			intervals [8]:
				xmin = 36.70599
				xmax = 40.78175
				text = "许多话题关于我"
			intervals [9]:
				xmin = 40.78175
				xmax = 44.99469
				text = "就连我也有听过"
			intervals [10]:
				xmin = 44.99469
				xmax = 49.05559
				text = "我的快乐要被认可"
			intervals [11]:
				xmin = 49.05559
				xmax = 52.99672
				text = "委屈却没有人诉说"
			intervals [12]:
				xmin = 52.99672
				xmax = 57.06552
				text = "夜把心洋葱般剥落"
			intervals [13]:
				xmin = 57.06552
				xmax = 61.19637
				text = "拿掉防卫剩下什么"
			intervals [14]:
				xmin = 61.19637
				xmax = 68.34643
				text = "为什么脆弱时候想你更多"
			intervals [15]:
				xmin = 68.34643
				xmax = 72.41947
				text = "如果你也听说"
			intervals [16]:
				xmin = 72.41947
				xmax = 76.55777
				text = "有没有想过我"
			intervals [17]:
				xmin = 76.55777
				xmax = 80.26
				text = "像普通旧朋友"
			intervals [18]:
				xmin = 80.26
				xmax = 85.42219
				text = "还是你依然会心疼我"
			intervals [19]:
				xmin = 85.42219
				xmax = 90.06673
				text = "好多好多的话想对你说"
			intervals [20]:
				xmin = 90.06673
				xmax = 94.20928
				text = "悬着一颗心没着落"
			intervals [21]:
