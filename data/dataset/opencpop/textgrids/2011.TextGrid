		class = "IntervalTier"
		name = "句子"
		xmin = 0.0
		xmax = 270.83755
		intervals: size = 49
			intervals [1]:
				xmin = 0.0
				xmax = 4.26641
				text = "silence"
			intervals [2]:
				xmin = 4.26641
				xmax = 8.68282
				text = "分手后第几个冬季"
			intervals [3]:
				xmin = 8.68282
				xmax = 11.92357
				text = "今天是星期几"
			intervals [4]:
				xmin = 11.92357
				xmax = 17.14678
				text = "偶尔会想起你"
			intervals [5]:
				xmin = 17.14678
				xmax = 24.61871
				text = "你突如其来的简讯让我措手不及"
			intervals [6]:
				xmin = 24.61871
				xmax = 30.16533
				text = "愣住站在原地"
			intervals [7]:
				xmin = 30.16533
				xmax = 33.4049
				text = "当所有人都替你开心"
			intervals [8]:
				xmin = 33.4049
				xmax = 41.24859
				text = "我却才傻傻清醒原来早已有人为你订做了嫁衣"
			intervals [9]:
				xmin = 41.24859
				xmax = 47.57598
				text = "感谢你特别邀请来见证你的爱情"
			intervals [10]:
				xmin = 47.57598
				xmax = 53.33641
				text = "我时刻提醒自己别逃避"
			intervals [11]:
				xmin = 53.33641
				xmax = 60.71172
				text = "拿着喜帖一步一步走近他精心布置的场地"
			intervals [12]:
				xmin = 60.71172
				xmax = 66.82755
				text = "可惜这是属于你的风景而我只是嘉宾"
			intervals [13]:
				xmin = 66.82755
				xmax = 73.1138
				text = "我放下所有回忆来成全你的爱情"
			intervals [14]:
				xmin = 73.1138
				xmax = 78.90374
				text = "却始终不愿相信这是命"
			intervals [15]:
				xmin = 78.90374
				xmax = 86.32564
				text = "好久不见的你有点疏离握手寒暄如此客气"
			intervals [16]:
				xmin = 86.32564
				xmax = 93.19805
				text = "何必要在他的面前刻意隐瞒我的世界有"
			intervals [17]:
				xmin = 93.19805
				xmax = 98.81404
				text = "过你"
			intervals [18]:
				xmin = 98.81404
				xmax = 102.9889
				text = "不知不觉钟声响起"
			intervals [19]:
				xmin = 102.9889
				xmax = 106.22435
				text = "你守候在原地"
			intervals [20]:
				xmin = 106.22435
				xmax = 111.59157
				text = "等待着他靠近"
			intervals [21]:
				xmin = 111.59157
				xmax = 118.9406
				text = "温柔的他单膝跪地钻戒缓缓戴进"
			intervals [22]:
				xmin = 118.9406
				xmax = 124.55895
				text = "你的无名指里"
			intervals [23]:
				xmin = 124.55895
				xmax = 130.17184
				text = "当所有人都替你开心我却才傻傻清醒"
			intervals [24]:
				xmin = 130.17184
				xmax = 135.66553
				text = "原来我们之间已没有任何关系"
			intervals [25]:
				xmin = 135.66553
				xmax = 141.96587
				text = "感谢你特别邀请来见证你的爱情"
			intervals [26]:
				xmin = 141.96587
				xmax = 147.71624
				text = "我时刻提醒自己别逃避"
			intervals [27]:
				xmin = 147.71624
				xmax = 151.53677
				text = "今天你妆扮得格外美丽"
			intervals [28]:
				xmin = 151.53677
				xmax = 158.81668
				text = "这美也曾拥在怀里可惜这是你和他的婚礼"
			intervals [29]:
				xmin = 158.81668
				xmax = 164.29308
				text = "而我只是嘉宾我放下所有回忆"
			intervals [30]:
				xmin = 164.29308
				xmax = 168.81884
				text = "来成全你的爱情却始终"
			intervals [31]:
				xmin = 168.81884
				xmax = 173.29275
				text = "不愿相信这是命"
			intervals [32]:
				xmin = 173.29275
				xmax = 180.72162
				text = "说好的永远变成了曾经我试着衷心祝福你"
			intervals [33]:
				xmin = 180.72162
				xmax = 184.33226
				text = "请原谅我不体面没出息"
			intervals [34]:
				xmin = 184.33226
				xmax = 191.7167
				text = "选择失陪一下先离席"
			intervals [35]:
				xmin = 191.7167
				xmax = 196.74603
				text = "又不是偶像剧怎么我演得"
			intervals [36]:
				xmin = 196.74603
				xmax = 200.17365
				text = "那么入戏"
			intervals [37]:
				xmin = 200.17365
				xmax = 205.92406
				text = "这不堪入目的剧情"
			intervals [38]:
				xmin = 205.92406
				xmax = 212.41701
				text = "感谢你特别邀请观赏你要的爱情"
			intervals [39]:
				xmin = 212.41701
				xmax = 218.13622
				text = "嘉宾也许是另一种宿命"
			intervals [40]:
				xmin = 218.13622
				xmax = 221.91715
				text = "离开你的自己事到如今"
			intervals [41]:
				xmin = 221.91715
				xmax = 229.20363
				text = "还有什么资格关心毕竟终成眷属的人是你                                                                                                                                                                                                                                           "
			intervals [42]:
				xmin = 229.20363
				xmax = 234.71294
				text = "而我只是嘉宾我流尽所有回忆"
			intervals [43]:
				xmin = 234.71294
				xmax = 237.92647
				text = "来庆祝你的婚礼"
			intervals [44]:
				xmin = 237.92647
				xmax = 243.75677
				text = "却始终没有勇气祝福你"
			intervals [45]:
				xmin = 243.75677
				xmax = 247.61703
				text = "谢谢你送给我最后清醒"
			intervals [46]:
				xmin = 247.61703
				xmax = 254.44396
				text = "把自己还给我自己"
			intervals [47]:
				xmin = 254.44396
				xmax = 259.51882
				text = "至少我还能够成为那个见证你们"
			intervals [48]:
				xmin = 259.51882
				xmax = 266.53621
				text = "爱情的嘉宾"
			intervals [49]:
				xmin = 266.53621
				xmax = 270.83755
				text = "silence"
