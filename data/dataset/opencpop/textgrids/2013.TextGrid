				text = "窗外雨都停了屋里灯还黑着"
			intervals [5]:
				xmin = 17.04316
				xmax = 20.69696
				text = "数着你的冷漠把玩着寂寞"
			intervals [6]:
				xmin = 20.69696
				xmax = 25.42108
				text = "电话还没拨已经口渴为你熬的夜都冷了"
			intervals [7]:
