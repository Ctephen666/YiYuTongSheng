			intervals [2]:
				xmin = 4.84915
				xmax = 12.06459
				text = "silence"
			intervals [3]:
				xmin = 12.06459
				xmax = 18.99178
				text = "后来我总算学会了如何去爱"
			intervals [4]:
				xmin = 18.99178
				xmax = 24.88859
				text = "可惜你早已远去消失在人海"
			intervals [5]:
				xmin = 24.88859
				xmax = 31.78256
				text = "后来终于在眼泪中明白"
			intervals [6]:
				xmin = 31.78256
				xmax = 39.32847
				text = "有些人一旦错过就不在"
			intervals [7]:
				xmin = 39.32847
				xmax = 45.76564
				text = "栀子花白花瓣"
			intervals [8]:
				xmin = 45.76564
				xmax = 51.32063
				text = "落在我蓝色百褶裙上"
			intervals [9]:
				xmin = 51.32063
				xmax = 58.56168
				text = "爱你你轻声说"
			intervals [10]:
				xmin = 58.56168
				xmax = 65.00625
				text = "我低下头闻见一阵芬芳"
			intervals [11]:
				xmin = 65.00625
				xmax = 71.8164
				text = "那个永恒的夜晚十七岁仲夏"
			intervals [12]:
				xmin = 71.8164
				xmax = 77.78945
				text = "你吻我的那个夜晚"
			intervals [13]:
				xmin = 77.78945
				xmax = 84.44566
				text = "让我往后的时光每当有感叹"
			intervals [14]:
				xmin = 84.44566
				xmax = 90.61002
				text = "总想起当天的星光"
			intervals [15]:
				xmin = 90.61002
				xmax = 97.04372
				text = "那时候的爱情"
			intervals [16]:
				xmin = 97.04372
				xmax = 102.27105
				text = "为什么就能那样简单"
			intervals [17]:
				xmin = 102.27105
				xmax = 109.88847
				text = "而又是为什么人年少时"
			intervals [18]:
				xmin = 109.88847
				xmax = 115.81765
				text = "一定要让深爱的人受伤"
			intervals [19]:
				xmin = 115.81765
				xmax = 120.2789
				text = "在这相似的深夜里"
			intervals [20]:
				xmin = 120.2789
				xmax = 123.4775
				text = "你是否一样也在"
			intervals [21]:
				xmin = 123.4775
				xmax = 129.05129
				text = "静静追悔感伤"
			intervals [22]:
				xmin = 129.05129
				xmax = 135.63351
				text = "如果当时我们能不那么倔强"
			intervals [23]:
				xmin = 135.63351
				xmax = 140.69423
				text = "现在也不那么遗憾"
			intervals [24]:
				xmin = 140.69423
				xmax = 143.7134
				text = "你都如何回忆我"
			intervals [25]:
				xmin = 143.7134
				xmax = 146.90749
				text = "带着笑或是很沉默"
			intervals [26]:
				xmin = 146.90749
