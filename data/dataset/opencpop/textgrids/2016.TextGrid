				text = "silence"
			intervals [4]:
				xmin = 19.26013
				xmax = 24.06795
				text = "爱情就像蓝蓝天上"
			intervals [5]:
				xmin = 24.06795
				xmax = 28.81433
				text = "一片留白有你陪我想象"
			intervals [6]:
				xmin = 28.81433
				xmax = 34.7083
				text = "白马突然不再抽象青蛙
"
			intervals [7]:
				xmin = 34.7083
				xmax = 37.76747
				text = "终于遇见灰姑娘"
			intervals [8]:
				xmin = 37.76747
				xmax = 44.08211
				text = "就算路还漫长我却有一种预感"
			intervals [9]:
				xmin = 44.08211
				xmax = 48.85415
				text = "我相信这灵感"
			intervals [10]:
				xmin = 48.85415
				xmax = 53.77758
				text = "我把你画成花未开的一朵花"
			intervals [11]:
				xmin = 53.77758
				xmax = 58.44213
				text = "再把思念一点一滴画成雨落下"
			intervals [12]:
				xmin = 58.44213
				xmax = 63.26297
				text = "每当我不在请记得我的爱"
			intervals [13]:
				xmin = 63.26297
				xmax = 67.86781
				text = "就在同一天空之下遥远地灌溉"
			intervals [14]:
				xmin = 67.86781
				xmax = 74.73315
				text = "等待秋去春来等待下一次花开"
			intervals [15]:
				xmin = 74.73315
				xmax = 80.87246
				text = "在咫尺的未来"
			intervals [16]:
				xmin = 80.87246
				xmax = 85.90255
				text = "生活就像茫茫海上"
			intervals [17]:
				xmin = 85.90255
