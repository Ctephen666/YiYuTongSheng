			intervals [5]:
				xmin = 24.75099
				xmax = 32.6457
				text = "总梦见那年白芍花开"
			intervals [6]:
				xmin = 32.6457
				xmax = 39.92493
				text = "我们牵着手走在白色花海"
			intervals [7]:
				xmin = 39.92493
				xmax = 44.74374
				text = "那时天空那么蓝"
			intervals [8]:
				xmin = 44.74374
				xmax = 47.98505
				text = "时间那么慢"
			intervals [9]:
				xmin = 47.98505
				xmax = 52.26748
				text = "记忆中的味道"
			intervals [10]:
				xmin = 52.26748
				xmax = 56.61516
				text = "那么甜"
			intervals [11]:
				xmin = 56.61516
				xmax = 64.53755
				text = "再次梦见那片白色海洋"
			intervals [12]:
				xmin = 64.53755
				xmax = 72.34294
				text = "仿佛一切停止在那瞬间"
			intervals [13]:
				xmin = 72.34294
				xmax = 80.12038
				text = "刻着你我的青春白色的约定"
			intervals [14]:
				xmin = 80.12038
				xmax = 84.12185
				text = "我不愿醒过来"
			intervals [15]:
				xmin = 84.12185
				xmax = 88.7971
				text = "这是最美丽的永远"
			intervals [16]:
				xmin = 88.7971
				xmax = 96.35254
				text = "转眼多年青涩渐远一切恍如昨天"
