				xmax = 25.809
				text = "silence"
			intervals [5]:
				xmin = 25.809
				xmax = 31.43376
				text = "风吹雨成花"
			intervals [6]:
				xmin = 31.43376
				xmax = 37.27052
				text = "时间追不上白马"
			intervals [7]:
				xmin = 37.27052
				xmax = 42.88033
				text = "你年少掌心的梦话依"
			intervals [8]:
				xmin = 42.88033
				xmax = 48.54374
				text = "然紧握着吗"
			intervals [9]:
				xmin = 48.54374
				xmax = 54.18392
				text = "云翻涌成夏"
			intervals [10]:
				xmin = 54.18392
				xmax = 59.7733
				text = "眼泪被岁月蒸发"
			intervals [11]:
				xmin = 59.7733
				xmax = 64.77637
				text = "这条路上的你我她"
			intervals [12]:
				xmin = 64.77637
				xmax = 68.93444
				text = "有谁迷路了吗"
			intervals [13]:
				xmin = 68.93444
				xmax = 73.90772
				text = "silence"
			intervals [14]:
				xmin = 73.90772
				xmax = 78.48538
				text = "我们说好不分离"
			intervals [15]:
				xmin = 78.48538
				xmax = 85.2167
				text = "要一直一直在一起"
			intervals [16]:
				xmin = 85.2167
				xmax = 89.81269
				text = "就算与时间为敌"
			intervals [17]:
				xmin = 89.81269
				xmax = 95.24365
				text = "就算与全世界背离"
			intervals [18]:
				xmin = 95.24365
				xmax = 101.43331
				text = "silence"
			intervals [19]:
				xmin = 101.43331
				xmax = 107.69833
				text = "silence"
			intervals [20]:
				xmin = 107.69833
				xmax = 113.37744
				text = "风吹亮雪花"
			intervals [21]:
				xmin = 113.37744
				xmax = 119.14245
				text = "吹白我们的头发"
			intervals [22]:
				xmin = 119.14245
				xmax = 124.06424
				text = "当初说一起闯天下"
			intervals [23]:
				xmin = 124.06424
				xmax = 130.34512
				text = "你们还记得吗"
			intervals [24]:
				xmin = 130.34512
				xmax = 135.93444
				text = "那一年盛夏"
			intervals [25]:
				xmin = 135.93444
				xmax = 141.71881
				text = "心愿许的无限大"
			intervals [26]:
				xmin = 141.71881
				xmax = 146.58668
				text = "我们手拉手也成舟"
			intervals [27]:
				xmin = 146.58668
				xmax = 151.26716
				text = "划过悲伤河流"
			intervals [28]:
				xmin = 151.26716
				xmax = 155.78071
				text = "silence"
			intervals [29]:
				xmin = 155.78071
				xmax = 160.39597
				text = "你曾说过不分离"
			intervals [30]:
				xmin = 160.39597
				xmax = 166.99047
				text = "要一直一直在一起"
			intervals [31]:
				xmin = 166.99047
				xmax = 171.56116
				text = "现在我想问问你"
			intervals [32]:
				xmin = 171.56116
				xmax = 178.38001
				text = "是否只是童言无忌"
			intervals [33]:
				xmin = 178.38001
				xmax = 182.96449
				text = "天真岁月不忍欺"
			intervals [34]:
				xmin = 182.96449
				xmax = 189.75388
				text = "青春荒唐我不负你"
			intervals [35]:
				xmin = 189.75388
				xmax = 194.31665
				text = "大雪求你别抹去"
			intervals [36]:
				xmin = 194.31665
				xmax = 201.01408
				text = "我们在一起的痕迹"
			intervals [37]:
				xmin = 201.01408
				xmax = 205.58842
				text = "大雪也无法抹去"
			intervals [38]:
				xmin = 205.58842
				xmax = 212.22378
				text = "我们给彼此的印记"
			intervals [39]:
				xmin = 212.22378
				xmax = 217.83536
				text = "今夕何夕"
			intervals [40]:
				xmin = 217.83536
				xmax = 223.55236
				text = "青草离离"
			intervals [41]:
				xmin = 223.55236
				xmax = 228.6676
				text = "明月夜送君千里"
			intervals [42]:
				xmin = 228.6676
				xmax = 234.40155
				text = "等来年秋风起"
			intervals [43]:
				xmin = 234.40155
				xmax = 241.47208
				text = "silence"
			intervals [44]:
				xmin = 241.47208
				xmax = 247.8498
