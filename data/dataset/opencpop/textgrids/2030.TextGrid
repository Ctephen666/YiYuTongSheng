	item [1]:
		class = "IntervalTier"
		name = "句子"
		xmin = 0.0
		xmax = 243.51347
		intervals: size = 41
			intervals [1]:
				xmin = 0.0
				xmax = 5.79558
				text = "silence"
			intervals [2]:
				xmin = 5.79558
				xmax = 12.77266
				text = "silence"
			intervals [3]:
				xmin = 12.77266
				xmax = 19.42975
				text = "就此告别吧水上的列车就快到站"
			intervals [4]:
				xmin = 19.42975
				xmax = 25.50506
				text = "开往未来的路上没有人会再回返"
			intervals [5]:
				xmin = 25.50506
				xmax = 32.28891
				text = "说声再见吧就算留恋也不要回头看"
			intervals [6]:
				xmin = 32.28891
				xmax = 40.09295
				text = "在那大海的彼端一定有空濛的彼岸"
			intervals [7]:
				xmin = 40.09295
				xmax = 45.90525
				text = "做最温柔的梦盛满世间行色匆匆"
			intervals [8]:
				xmin = 45.90525
				xmax = 52.97337
				text = "在渺茫的时空在千百万人之中听一听心声"
			intervals [9]:
				xmin = 52.97337
				xmax = 58.30802
				text = "一路不断失去一生将不断见证"
			intervals [10]:
				xmin = 58.30802
				xmax = 63.90344
				text = "看过再多风景眼眸如初清澄爱依旧"
			intervals [11]:
				xmin = 63.90344
				xmax = 67.33277
				text = "让你动容"
			intervals [12]:
				xmin = 67.33277
				xmax = 73.80078
				text = "亲爱的旅人没有一条路无风无浪"
			intervals [13]:
				xmin = 73.80078
				xmax = 80.18776
				text = "会有孤独会有悲伤也会有无尽的希望"
			intervals [14]:
				xmin = 80.18776
				xmax = 86.97143
				text = "亲爱的旅人这一程会短暂却又漫长"
			intervals [15]:
				xmin = 86.97143
				xmax = 94.6788
				text = "而一切终将汇聚成最充盈的景象"
			intervals [16]:
				xmin = 94.6788
				xmax = 100.62072
				text = "啦啦啦啦啦啦啦啦啦啦啦啦啦啦"
			intervals [17]:
				xmin = 100.62072
				xmax = 107.58516
				text = "啦啦啦啦啦啦啦啦啦啦啦啦啦啦啦啦啦啦"
			intervals [18]:
				xmin = 107.58516
				xmax = 114.59735
				text = "嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟嘟"
			intervals [19]:
				xmin = 114.59735
				xmax = 122.01505
				text = "呜呜呜呜呜呜呜呜呜呜呜呜"
			intervals [20]:
				xmin = 122.01505
				xmax = 128.64843
				text = "就此告别吧身后的灯火逐渐暗淡"
			intervals [21]:
				xmin = 128.64843
				xmax = 134.75919
				text = "每个恋家的孩子都要扬起远行的帆"
			intervals [22]:
				xmin = 134.75919
				xmax = 141.58355
				text = "说声再见吧美好的梦境不会消散"
			intervals [23]:
				xmin = 141.58355
				xmax = 149.36888
				text = "你的爱枕在臂弯心脏将毕生柔软"
			intervals [24]:
				xmin = 149.36888
				xmax = 155.2597
				text = "既然相遇是种来自于时光的馈赠"
			intervals [25]:
				xmin = 155.2597
				xmax = 162.09074
				text = "那么离别时也一定要微笑着回忆放心中"
			intervals [26]:
				xmin = 162.09074
				xmax = 167.64654
				text = "生命无限渺小却同样无限恢弘"
			intervals [27]:
				xmin = 167.64654
				xmax = 173.17195
				text = "你为寻找或是告别耗尽一生也足够"
			intervals [28]:
				xmin = 173.17195
				xmax = 176.6139
				text = "让人心动"
			intervals [29]:
				xmin = 176.6139
				xmax = 183.03633
				text = "亲爱的旅人你仍是记忆中的模样"
			intervals [30]:
				xmin = 183.03633
				xmax = 189.5512
				text = "穿过人群走过人间再去往更远的远方"
			intervals [31]:
				xmin = 189.5512
				xmax = 196.26648
				text = "你灵魂深处总要有这样一个地方"
			intervals [32]:
				xmin = 196.26648
				xmax = 199.47126
				text = "永远在海面漂荡"
			intervals [33]:
				xmin = 199.47126
				xmax = 202.35519
				text = "在半空中飞扬"
			intervals [34]:
				xmin = 202.35519
				xmax = 205.67872
				text = "永远轻盈永远滚烫"
			intervals [35]:
				xmin = 205.67872
				xmax = 210.30725
				text = "不愿下沉不肯下降"
			intervals [36]:
				xmin = 210.30725
				xmax = 216.33871
				text = "啦啦啦啦啦啦啦啦啦啦啦啦啦啦 "
