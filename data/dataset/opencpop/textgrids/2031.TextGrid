				xmax = 33.09741
				text = "你竟然能做到"
			intervals [8]:
				xmin = 33.09741
				xmax = 38.24223
				text = "带走阳光"
			intervals [9]:
				xmin = 38.24223
				xmax = 42.2519
				text = "我一味的跟随"
			intervals [10]:
				xmin = 42.2519
				xmax = 47.57301
				text = "过了量"
			intervals [11]:
				xmin = 47.57301
				xmax = 50.32327
				text = "像风一样"
			intervals [12]:
				xmin = 50.32327
				xmax = 54.51388
				text = "你靠近云都下降"
			intervals [13]:
				xmin = 54.51388
				xmax = 58.6554
				text = "你卷起千层海浪"
			intervals [14]:
				xmin = 58.6554
				xmax = 62.79601
				text = "我躲也不躲往里闯"
			intervals [15]:
				xmin = 62.79601
				xmax = 67.225
				text = "你不就像风一样"
			intervals [16]:
				xmin = 67.225
				xmax = 71.49596
				text = "侵略时沙沙作响"
			intervals [17]:
				xmin = 71.49596
				xmax = 75.72499
				text = "再宣布恢复晴朗"
			intervals [18]:
				xmin = 75.72499
				xmax = 80.32496
				text = "就好像我们两个没"
			intervals [19]:
				xmin = 80.32496
				xmax = 85.7799
				text = "爱过一样"
			intervals [20]:
				xmin = 85.7799
				xmax = 88.70775
