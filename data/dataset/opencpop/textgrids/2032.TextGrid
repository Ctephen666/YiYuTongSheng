			intervals [5]:
				xmin = 23.963
				xmax = 29.72167
				text = "亲爱的你躲在哪里发呆"
			intervals [6]:
				xmin = 29.72167
				xmax = 35.47987
				text = "有什么心事还无法释怀"
			intervals [7]:
				xmin = 35.47987
				xmax = 41.04052
				text = "我们总把人生想得太坏"
			intervals [8]:
				xmin = 41.04052
				xmax = 46.88623
				text = "像旁人不允许我们的怪"
			intervals [9]:
				xmin = 46.88623
				xmax = 52.59922
				text = "每一片与众不同的云彩"
			intervals [10]:
				xmin = 52.59922
				xmax = 58.39774
				text = "都需要找到天空去存在"
			intervals [11]:
				xmin = 58.39774
				xmax = 63.95058
				text = "我们都习惯了原地徘徊"
			intervals [12]:
				xmin = 63.95058
				xmax = 70.37855
				text = "却无法习惯被依赖"
			intervals [13]:
				xmin = 70.37855
				xmax = 77.11982
				text = "你给我这一辈子都不想失联的爱"
			intervals [14]:
				xmin = 77.11982
				xmax = 82.17197
				text = "相信爱的征途就是星辰大海"
			intervals [15]:
				xmin = 82.17197
				xmax = 87.49668
				text = "美好剧情不会更改"
			intervals [16]:
				xmin = 87.49668
				xmax = 93.31181
				text = "是命运最好的安排"
			intervals [17]:
				xmin = 93.31181
