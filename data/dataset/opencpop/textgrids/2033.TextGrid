		intervals: size = 22
			intervals [1]:
				xmin = 0.0
				xmax = 7.31948
				text = "silence"
			intervals [2]:
				xmin = 7.31948
				xmax = 15.20909
				text = "silence"
			intervals [3]:
				xmin = 15.20909
				xmax = 18.3574
				text = "星星一直都在"
			intervals [4]:
				xmin = 18.3574
				xmax = 21.98763
				text = "这一片云海"
			intervals [5]:
				xmin = 21.98763
				xmax = 29.92977
				text = "等着太阳疲倦之后离开"
			intervals [6]:
				xmin = 29.92977
				xmax = 32.90092
				text = "我也一直待在"
			intervals [7]:
				xmin = 32.90092
				xmax = 36.41225
				text = "这个模糊地带"
			intervals [8]:
				xmin = 36.41225
				xmax = 43.05447
				text = "等着你疲倦了回来"
			intervals [9]:
				xmin = 43.05447
				xmax = 46.66256
				text = "天黑之后才拥有光彩"
			intervals [10]:
				xmin = 46.66256
				xmax = 50.38893
				text = "才能看见微弱的存在"
			intervals [11]:
				xmin = 50.38893
				xmax = 57.6868
				text = "我就好像星星在距你千里之外"
			intervals [12]:
				xmin = 57.6868
				xmax = 61.2868
				text = "白云总是对蓝天依赖"
			intervals [13]:
				xmin = 61.2868
				xmax = 64.96258
				text = "我的爱也因你而存在"
			intervals [14]:
				xmin = 64.96258
				xmax = 72.19881
				text = "哪怕你不懂我的感慨和等待"
			intervals [15]:
				xmin = 72.19881
				xmax = 75.71444
				text = "我的爱像尘埃"
			intervals [16]:
				xmin = 75.71444
				xmax = 79.51735
				text = "散落在边疆地带"
			intervals [17]:
				xmin = 79.51735
				xmax = 81.98019
				text = "不再对谁期待"
			intervals [18]:
				xmin = 81.98019
				xmax = 86.80169
				text = "难道是一种自由自在"
			intervals [19]:
				xmin = 86.80169
				xmax = 90.41486
				text = "而承诺像尘埃"
			intervals [20]:
				xmin = 90.41486
				xmax = 95.01676
				text = "不断被时间掩埋"
			intervals [21]:
				xmin = 95.01676
				xmax = 101.46498
				text = "谁还记得大雨之中的告白"
			intervals [22]:
				xmin = 101.46498
				xmax = 107.88571
				text = "silence"
