				xmax = 20.86081
				text = "silence"
			intervals [4]:
				xmin = 20.86081
				xmax = 25.85956
				text = "我的世界变得奇妙更难以言喻"
			intervals [5]:
				xmin = 25.85956
				xmax = 30.28246
				text = "还以为是从天而降的梦境"
			intervals [6]:
				xmin = 30.28246
				xmax = 35.27372
				text = "直到确定手的温度来自你心里"
			intervals [7]:
				xmin = 35.27372
				xmax = 40.2733
				text = "这一刻我终于勇敢说爱你"
			intervals [8]:
				xmin = 40.2733
				xmax = 44.36373
				text = "一开始我只顾着看你装做不经意心却飘过去"
			intervals [9]:
				xmin = 44.36373
				xmax = 49.11161
				text = "还窃喜你没发现我躲在角落"
			intervals [10]:
				xmin = 49.11161
				xmax = 54.65608
				text = "忙着快乐忙着感动从彼此陌生到熟会是我们从没想过"
			intervals [11]:
				xmin = 54.65608
				xmax = 59.69645
				text = "真爱到现在不敢期待"
			intervals [12]:
				xmin = 59.69645
				xmax = 64.38469
				text = "要证明自己曾被你想起瑞丽"
			intervals [13]:
				xmin = 64.38469
				xmax = 69.00529
				text = "我胡思乱想就从今天起爱你"
			intervals [14]:
				xmin = 69.00529
				xmax = 75.55697
				text = "像一个陷阱却从未犹豫相信你真的愿意"
			intervals [15]:
				xmin = 75.55697
				xmax = 82.3206
				text = "就请给我惊喜关于爱情过去没有异想的结局"
			intervals [16]:
				xmin = 82.3206
				xmax = 86.74429
				text = "那天起却颠覆了自己逻辑"
			intervals [17]:
				xmin = 86.74429
				xmax = 91.73541
				text = "我的怀疑所有答案因你而明白"
			intervals [18]:
