			intervals [7]:
				xmin = 39.08222
				xmax = 42.09444
				text = "我无法帮你预言"
			intervals [8]:
				xmin = 42.09444
				xmax = 46.02097
				text = "委曲求全有没有用"
			intervals [9]:
				xmin = 46.02097
				xmax = 49.07537
				text = "可是我多么不舍"
			intervals [10]:
				xmin = 49.07537
				xmax = 52.99233
				text = "朋友爱得那么苦痛"
			intervals [11]:
				xmin = 52.99233
				xmax = 55.99062
				text = "爱可以不问对错"
			intervals [12]:
				xmin = 55.99062
				xmax = 58.67674
				text = "至少有喜悦感动"
			intervals [13]:
				xmin = 58.67674
				xmax = 62.03578
				text = "如果他总为别人撑伞"
			intervals [14]:
				xmin = 62.03578
				xmax = 66.87626
				text = "你何苦非为他等在雨中"
			intervals [15]:
				xmin = 66.87626
				xmax = 69.86111
				text = "泡咖啡让你暖手"
			intervals [16]:
				xmin = 69.86111
				xmax = 73.88984
				text = "想挡挡你心口里的风"
			intervals [17]:
				xmin = 73.88984
				xmax = 76.85429
				text = "你却想上街走走"
			intervals [18]:
				xmin = 76.85429
				xmax = 80.88242
				text = "吹吹冷风会清醒得多"
			intervals [19]:
				xmin = 80.88242
				xmax = 83.82544
				text = "你说你不怕分手"
			intervals [20]:
				xmin = 83.82544
				xmax = 86.41879
				text = "只有点遗憾难过"
			intervals [21]:
				xmin = 86.41879
				xmax = 88.76637
				text = "情人节就要来了"
			intervals [22]:
				xmin = 88.76637
				xmax = 92.38839
				text = "剩自己一个其实爱对了人"
			intervals [23]:
				xmin = 92.38839
				xmax = 96.41176
				text = "情人节每天都过"
			intervals [24]:
				xmin = 96.41176
				xmax = 99.93027
				text = "分手快乐祝你快乐"
			intervals [25]:
				xmin = 99.93027
