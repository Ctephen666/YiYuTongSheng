			intervals [5]:
				xmin = 28.94103
				xmax = 35.58513
				text = "小学篱笆旁的蒲公英"
			intervals [6]:
				xmin = 35.58513
				xmax = 42.89672
				text = "是记忆里有味道的风景"
			intervals [7]:
				xmin = 42.89672
				xmax = 49.93877
				text = "午睡操场传来蝉的声音"
			intervals [8]:
				xmin = 49.93877
				xmax = 57.326
				text = "多少年后也还是很好听"
			intervals [9]:
				xmin = 57.326
				xmax = 64.02066
				text = "将愿望折纸飞机寄成信"
			intervals [10]:
				xmin = 64.02066
				xmax = 70.9482
				text = "因为我们等不到那流星"
			intervals [11]:
				xmin = 70.9482
				xmax = 78.04477
				text = "认真投决定命运的硬币"
			intervals [12]:
				xmin = 78.04477
				xmax = 85.13876
				text = "却不知道到底能去哪里"
			intervals [13]:
				xmin = 85.13876
				xmax = 90.44209
				text = "一起长大的约定"
			intervals [14]:
				xmin = 90.44209
				xmax = 95.75803
				text = "那样清晰打过勾的"
			intervals [15]:
				xmin = 95.75803
				xmax = 99.10907
				text = "我相信"
			intervals [16]:
				xmin = 99.10907
				xmax = 104.42402
