				text = "silence"
			intervals [3]:
				xmin = 14.35645
				xmax = 22.3279
				text = "silence"
			intervals [4]:
				xmin = 22.3279
				xmax = 27.75739
				text = "我们都曾因寂寞而给对方承诺"
			intervals [5]:
				xmin = 27.75739
				xmax = 32.90987
				text = "我们都因为折磨而厌倦了生活"
			intervals [6]:
				xmin = 32.90987
				xmax = 38.76596
				text = "只是这样的日子同样的方式"
			intervals [7]:
				xmin = 38.76596
				xmax = 45.93151
				text = "还要多久"
			intervals [8]:
				xmin = 45.93151
				xmax = 51.15452
				text = "我们改变了态度而接纳了对方"
			intervals [9]:
				xmin = 51.15452
				xmax = 56.53896
				text = "我们委屈了自己成全谁的梦想"
			intervals [10]:
				xmin = 56.53896
				xmax = 62.63673
				text = "只是这样的日子还需要多少"
			intervals [11]:
				xmin = 62.63673
				xmax = 70.05682
				text = "已不重要"
			intervals [12]:
				xmin = 70.05682
				xmax = 75.6694
				text = "时常想起过去的温存"
			intervals [13]:
				xmin = 75.6694
				xmax = 81.12368
				text = "它让我在夜里不会冷"
			intervals [14]:
				xmin = 81.12368
				xmax = 86.56601
				text = "你说一个人的美丽是认真"
			intervals [15]:
				xmin = 86.56601
				xmax = 94.43709
				text = "两个人能在一起是缘分"
			intervals [16]:
				xmin = 94.43709
				xmax = 100.23326
				text = "早知道是这样像梦一场"
			intervals [17]:
				xmin = 100.23326
				xmax = 105.71781
				text = "我才不会把爱都放在同一个地方"
			intervals [18]:
				xmin = 105.71781
				xmax = 110.70085
				text = "我能原谅你的荒唐"
			intervals [19]:
				xmin = 110.70085
				xmax = 115.7663
				text = "荒唐的是我没有办法遗忘"
			intervals [20]:
				xmin = 115.7663
				xmax = 121.51874
				text = "早知道是这样如梦一场"
			intervals [21]:
				xmin = 121.51874
				xmax = 127.04236
				text = "我又何必把泪都锁在自己的眼眶"
