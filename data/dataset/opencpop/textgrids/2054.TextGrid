			intervals [4]:
				xmin = 17.99625
				xmax = 24.89104
				text = "你说你想在海边买一所房子"
			intervals [5]:
				xmin = 24.89104
				xmax = 32.69489
				text = "和你可爱的松狮一起住在那里"
			intervals [6]:
				xmin = 32.69489
				xmax = 36.86892
				text = "你会当一个心情杂货铺的老"
			intervals [7]:
				xmin = 36.86892
				xmax = 39.39967
				text = "板娘"
			intervals [8]:
				xmin = 39.39967
				xmax = 43.65468
				text = "随着心情卖着自己喜欢的"
			intervals [9]:
				xmin = 43.65468
				xmax = 47.49727
				text = "东西"
			intervals [10]:
				xmin = 47.49727
				xmax = 51.12677
				text = "生活越来越压抑"
			intervals [11]:
				xmin = 51.12677
				xmax = 54.98177
				text = "你变得越来越不像自己"
			intervals [12]:
				xmin = 54.98177
				xmax = 62.3541
				text = "一个人站在悲催的风里"
			intervals [13]:
				xmin = 62.3541
				xmax = 65.751
				text = "玫瑰你在哪里"
			intervals [14]:
				xmin = 65.751
				xmax = 69.70369
				text = "你说你爱过的人都已经离去"
			intervals [15]:
				xmin = 69.70369
				xmax = 73.16911
				text = "不要欺骗自己"
			intervals [16]:
				xmin = 73.16911
				xmax = 77.13149
				text = "你只是隐藏的比较深而已"
			intervals [17]:
				xmin = 77.13149
				xmax = 80.58707
				text = "玫瑰你在哪里"
			intervals [18]:
				xmin = 80.58707
