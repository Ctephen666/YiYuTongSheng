			intervals [3]:
				xmin = 14.03588
				xmax = 17.22085
				text = "熟悉的陌生的这种感觉"
			intervals [4]:
				xmin = 17.22085
				xmax = 20.38482
				text = "重复的曾经的那些情节"
			intervals [5]:
				xmin = 20.38482
				xmax = 26.51174
				text = "也只是怀念"
			intervals [6]:
				xmin = 26.51174
				xmax = 29.49546
				text = "一滴滴一点点一页一篇"
			intervals [7]:
				xmin = 29.49546
				xmax = 32.18521
				text = "分手了也不过三百多天"
			intervals [8]:
				xmin = 32.18521
				xmax = 37.1537
				text = "可我却害怕遇见"
			intervals [9]:
				xmin = 37.1537
				xmax = 40.14638
				text = "我懵懵懂懂过了一年"
			intervals [10]:
				xmin = 40.14638
				xmax = 43.20877
				text = "这一年似乎没有改变"
			intervals [11]:
				xmin = 43.20877
				xmax = 45.70641
				text = "守着你离开后的世界"
			intervals [12]:
				xmin = 45.70641
				xmax = 49.41347
				text = "空空如也"
			intervals [13]:
				xmin = 49.41347
				xmax = 52.50896
