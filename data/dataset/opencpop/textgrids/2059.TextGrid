			intervals [5]:
				xmin = 30.24706
				xmax = 37.69043
				text = "silence"
			intervals [6]:
				xmin = 37.69043
				xmax = 44.47756
				text = "这一刻突然觉得好熟悉"
			intervals [7]:
				xmin = 44.47756
				xmax = 50.98848
				text = "像昨天今天同时在放映"
			intervals [8]:
				xmin = 50.98848
				xmax = 57.60861
				text = "我这句语气原来好像你"
			intervals [9]:
				xmin = 57.60861
				xmax = 64.04077
				text = "不就是我们爱过的证据"
			intervals [10]:
				xmin = 64.04077
				xmax = 70.5236
				text = "差一点骗了自己骗了你"
			intervals [11]:
				xmin = 70.5236
				xmax = 76.96949
				text = "爱与被爱不一定成正比"
			intervals [12]:
				xmin = 76.96949
				xmax = 83.47958
				text = "我知道被疼是一种运气"
			intervals [13]:
				xmin = 83.47958
				xmax = 89.68547
				text = "但我无法完全交出自己"
			intervals [14]:
				xmin = 89.68547
				xmax = 96.16822
				text = "努力为你改变却变不了预留的伏线"
			intervals [15]:
				xmin = 96.16822
				xmax = 102.69203
				text = "以为在你身边那也算永远"
			intervals [16]:
				xmin = 102.69203
				xmax = 109.14422
				text = "仿佛还是昨天可是昨天已非常遥远"
			intervals [17]:
				xmin = 109.14422
				xmax = 116.14282
				text = "但闭上我双眼我还看得见"
			intervals [18]:
				xmin = 116.14282
				xmax = 119.6123
				text = "可惜不是你"
			intervals [19]:
				xmin = 119.6123
				xmax = 122.74968
				text = "陪我到最后"
			intervals [20]:
				xmin = 122.74968
				xmax = 129.36413
				text = "曾一起走却走失那路口"
			intervals [21]:
				xmin = 129.36413
				xmax = 132.51624
				text = "感谢那是你"
			intervals [22]:
				xmin = 132.51624
				xmax = 135.74947
				text = "牵过我的手"
			intervals [23]:
				xmin = 135.74947
				xmax = 142.09904
				text = "还能感受那温柔"
			intervals [24]:
				xmin = 142.09904
				xmax = 148.64874
				text = "那一段我们曾心贴着心"
			intervals [25]:
				xmin = 148.64874
				xmax = 155.07322
				text = "我想我更有权利关心你"
			intervals [26]:
