			intervals [4]:
				xmin = 20.15919
				xmax = 23.33294
				text = "阴天在不开灯的房间"
			intervals [5]:
				xmin = 23.33294
				xmax = 26.90448
				text = "当所有思绪都一点一点沉淀"
			intervals [6]:
				xmin = 26.90448
				xmax = 29.99144
				text = "爱情究竟是精神鸦片"
			intervals [7]:
				xmin = 29.99144
				xmax = 34.41639
				text = "还是世纪末的无聊消遣"
			intervals [8]:
				xmin = 34.41639
				xmax = 37.62757
				text = "香烟氲成一滩光圈"
			intervals [9]:
				xmin = 37.62757
				xmax = 41.07716
				text = "和他的照片就摆在手边"
			intervals [10]:
				xmin = 41.07716
				xmax = 47.48562
				text = "傻傻两个人笑得多甜"
			intervals [11]:
				xmin = 47.48562
				xmax = 51.43425
				text = "开始总是分分钟都妙不可言"
			intervals [12]:
				xmin = 51.43425
				xmax = 55.00788
				text = "谁都以为热情它永不会减"
			intervals [13]:
				xmin = 55.00788
				xmax = 61.75936
				text = "除了激情褪去后的那一点点倦"
			intervals [14]:
				xmin = 61.75936
				xmax = 65.77713
				text = "也许像谁说过的贪得无厌"
			intervals [15]:
				xmin = 65.77713
				xmax = 69.3471
				text = "活该应了谁说过的不知检点"
			intervals [16]:
				xmin = 69.3471
				xmax = 75.2005
				text = "总之那几年感性赢了理性的那一面"
			intervals [17]:
				xmin = 75.2005
				xmax = 82.17617
				text = "silence"
			intervals [18]:
