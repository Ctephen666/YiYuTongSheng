			intervals [2]:
				xmin = 2.10061
				xmax = 7.04678
				text = "噢人都应该有梦"
			intervals [3]:
				xmin = 7.04678
				xmax = 11.51801
				text = "有梦就别怕痛"
			intervals [4]:
				xmin = 11.51801
				xmax = 16.59478
				text = "有雷声在轰不停雨泼进眼里看不清"
			intervals [5]:
				xmin = 16.59478
				xmax = 21.77327
				text = "谁急速狂飙溅我一身的泥泞"
			intervals [6]:
				xmin = 21.77327
				xmax = 24.31964
				text = "我决定我想去哪里"
			intervals [7]:
				xmin = 24.31964
				xmax = 26.86029
				text = "往天堂要跳过地狱"
			intervals [8]:
				xmin = 26.86029
				xmax = 30.17047
				text = "也不恐惧不逃避"
			intervals [9]:
				xmin = 30.17047
				xmax = 35.30824
				text = "这不是脾气是所谓志气"
			intervals [10]:
				xmin = 35.30824
				xmax = 39.15784
				text = "与勇气你能推我下悬崖"
			intervals [11]:
				xmin = 39.15784
				xmax = 45.42939
				text = "我能学会飞行从不听谁的命令"
			intervals [12]:
				xmin = 45.42939
				xmax = 51.25233
				text = "很独立耳朵用来听自己的心灵"
			intervals [13]:
				xmin = 51.25233
				xmax = 56.83146
				text = "淋雨一直走是一颗宝石就该闪烁"
