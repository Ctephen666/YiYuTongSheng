			intervals [3]:
				xmin = 15.39139
				xmax = 20.92871
				text = "教室里那台风琴叮咚叮咚叮咛"
			intervals [4]:
				xmin = 20.92871
				xmax = 24.25502
				text = "像你告白的声音"
			intervals [5]:
				xmin = 24.25502
				xmax = 27.0341
				text = "动作一直很轻"
			intervals [6]:
				xmin = 27.0341
				xmax = 30.21817
				text = "微笑看你送完信"
			intervals [7]:
				xmin = 30.21817
				xmax = 33.34317
				text = "转身离开的背影"
			intervals [8]:
				xmin = 33.34317
				xmax = 40.99441
				text = "喜欢你字迹清秀的关心"
			intervals [9]:
				xmin = 40.99441
				xmax = 46.6096
				text = "那温热的牛奶瓶在我手中握紧"
			intervals [10]:
				xmin = 46.6096
				xmax = 49.4097
				text = "有你在的地方"
			intervals [11]:
				xmin = 49.4097
				xmax = 52.62304
				text = "我总感觉很窝心"
			intervals [12]:
				xmin = 52.62304
				xmax = 55.75629
				text = "日子像旋转木马"
			intervals [13]:
				xmin = 55.75629
				xmax = 58.9717
				text = "在脑海里转不停"
			intervals [14]:
				xmin = 58.9717
				xmax = 66.12799
				text = "出现那些你对我好的场景"
			intervals [15]:
				xmin = 66.12799
				xmax = 72.64488
				text = "你说过牵了手就算约定"
			intervals [16]:
				xmin = 72.64488
				xmax = 78.99021
				text = "但亲爱的那并不是爱情"
			intervals [17]:
				xmin = 78.99021
				xmax = 85.37099
				text = "就像来不及许愿的流星"
			intervals [18]:
