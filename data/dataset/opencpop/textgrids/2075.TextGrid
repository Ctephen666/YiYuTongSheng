			intervals [8]:
				xmin = 33.5315
				xmax = 38.30267
				text = "于鲜活的枝丫凋零下的无暇 "
			intervals [9]:
				xmin = 38.30267
				xmax = 42.22268
				text = "是收获谜底的代价 "
			intervals [10]:
				xmin = 42.22268
				xmax = 45.57282
				text = "余晖沾上远行人的发 "
			intervals [11]:
				xmin = 45.57282
				xmax = 51.50422
				text = "他洒下手中牵挂于桥下 "
			intervals [12]:
				xmin = 51.50422
				xmax = 56.91171
				text = "前世迟来者掌心刻"
			intervals [13]:
				xmin = 56.91171
				xmax = 61.74019
				text = "你眼中烟波滴落一滴墨喔"
			intervals [14]:
				xmin = 61.74019
				xmax = 66.58288
				text = "若佛说放下执着"
			intervals [15]:
				xmin = 66.58288
				xmax = 70.77646
				text = "我怎能波澜不惊去附和"
			intervals [16]:
