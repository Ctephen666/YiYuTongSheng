	item [1]:
		class = "IntervalTier"
		name = "句子"
		xmin = 0.0
		xmax = 241.21469
		intervals: size = 42
			intervals [1]:
				xmin = 0.0
				xmax = 7.83649
				text = "silence"
			intervals [2]:
				xmin = 7.83649
				xmax = 14.33631
				text = "silence"
			intervals [3]:
				xmin = 14.33631
				xmax = 21.01395
				text = "silence"
			intervals [4]:
				xmin = 21.01395
				xmax = 28.42637
				text = "silence"
			intervals [5]:
				xmin = 28.42637
				xmax = 34.10136
				text = "匆匆那年我们究竟说了几遍再见之后再拖延"
			intervals [6]:
				xmin = 34.10136
				xmax = 39.72027
				text = "可惜谁有没有爱过不是一场七情上面的雄辩"
			intervals [7]:
				xmin = 39.72027
				xmax = 45.31744
				text = "匆匆那年我们一时匆忙撂下难以承受的诺言"
			intervals [8]:
				xmin = 45.31744
				xmax = 51.03366
				text = "只有等别人兑现"
			intervals [9]:
				xmin = 51.03366
				xmax = 56.58488
				text = "不怪那吻痕还没积累成茧"
			intervals [10]:
				xmin = 56.58488
				xmax = 62.30278
				text = "拥抱着冬眠也没能羽化再成仙"
			intervals [11]:
				xmin = 62.30278
				xmax = 67.7219
				text = "不怪这一段情没空反复再排练"
			intervals [12]:
				xmin = 67.7219
				xmax = 71.78889
				text = "是岁月宽容恩赐"
			intervals [13]:
				xmin = 71.78889
				xmax = 78.55641
				text = "反悔的时间"
			intervals [14]:
				xmin = 78.55641
				xmax = 84.70471
				text = "如果再见不能红着眼是否还能红着脸"
			intervals [15]:
				xmin = 84.70471
				xmax = 89.84211
				text = "就像那年匆促刻下永远一起那样美丽的谣言"
			intervals [16]:
				xmin = 89.84211
				xmax = 95.81303
				text = "如果过去还值得眷恋别太快冰释前嫌"
			intervals [17]:
				xmin = 95.81303
				xmax = 101.52177
				text = "谁甘心就这样彼此无挂也无牵"
			intervals [18]:
				xmin = 101.52177
				xmax = 107.08637
				text = "我们要互相亏欠"
			intervals [19]:
				xmin = 107.08637
				xmax = 111.83417
				text = "要不然凭何怀缅"
			intervals [20]:
				xmin = 111.83417
				xmax = 118.43983
				text = "silence"
			intervals [21]:
				xmin = 118.43983
				xmax = 124.10134
				text = "匆匆那年我们见过太少世面只爱看同一张脸"
			intervals [22]:
				xmin = 124.10134
				xmax = 129.65631
				text = "那么莫名其妙那么讨人欢喜闹起来又太讨厌"
			intervals [23]:
				xmin = 129.65631
				xmax = 135.33534
				text = "相爱那年活该匆匆因为我们不懂顽固的诺言"
			intervals [24]:
				xmin = 135.33534
				xmax = 140.99585
				text = "只是分手的前言"
			intervals [25]:
				xmin = 140.99585
				xmax = 146.55797
				text = "不怪那天太冷泪滴水成冰"
			intervals [26]:
				xmin = 146.55797
				xmax = 152.20939
				text = "春风也一样没吹进凝固的照片"
			intervals [27]:
				xmin = 152.20939
				xmax = 157.74763
				text = "不怪每一个人没能完整爱一遍"
			intervals [28]:
				xmin = 157.74763
				xmax = 161.7891
				text = "是岁月善意落下"
			intervals [29]:
				xmin = 161.7891
				xmax = 168.48215
				text = "残缺的悬念"
			intervals [30]:
				xmin = 168.48215
				xmax = 174.71033
				text = "如果再见不能红着眼是否还能红着脸"
			intervals [31]:
