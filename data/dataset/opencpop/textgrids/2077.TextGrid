			intervals [3]:
				xmin = 14.82286
				xmax = 21.28403
				text = "silence"
			intervals [4]:
				xmin = 21.28403
				xmax = 27.5943
				text = "silence"
			intervals [5]:
				xmin = 27.5943
				xmax = 34.45818
				text = "窗外的麻雀在电线杆上多嘴"
			intervals [6]:
				xmin = 34.45818
				xmax = 41.11846
				text = "你说这一句很有夏天的感觉"
			intervals [7]:
				xmin = 41.11846
				xmax = 47.5738
				text = "手中的铅笔在纸上来来回回"
			intervals [8]:
				xmin = 47.5738
				xmax = 54.21037
				text = "我用几行字形容你是我的谁"
			intervals [9]:
				xmin = 54.21037
				xmax = 61.36351
				text = "秋刀鱼的滋味猫跟你都想了解"
			intervals [10]:
				xmin = 61.36351
				xmax = 67.6991
				text = "初恋的香味就这样被我们寻回"
			intervals [11]:
				xmin = 67.6991
				xmax = 74.11501
				text = "那温暖的阳光像刚摘的鲜艳草莓"
			intervals [12]:
				xmin = 74.11501
				xmax = 80.87329
				text = "你说你舍不得吃掉这一种感觉"
			intervals [13]:
				xmin = 80.87329
				xmax = 87.63302
				text = "雨下整夜我的爱溢出就像雨水"
			intervals [14]:
				xmin = 87.63302
				xmax = 94.34172
				text = "院子落叶跟我的思念厚厚一叠"
			intervals [15]:
				xmin = 94.34172
				xmax = 101.95193
				text = "几句是非也无法将我的热情冷却"
			intervals [16]:
				xmin = 101.95193
				xmax = 107.90491
				text = "你出现在我诗的每一页"
			intervals [17]:
				xmin = 107.90491
				xmax = 114.5946
				text = "雨下整夜我的爱溢出就像雨水"
			intervals [18]:
				xmin = 114.5946
				xmax = 121.39167
				text = "窗台蝴蝶像诗里纷飞的美丽章节"
			intervals [19]:
				xmin = 121.39167
				xmax = 128.96425
				text = "我接着写把永远爱你写进诗的结尾"
			intervals [20]:
				xmin = 128.96425
				xmax = 134.55854
				text = "你是我唯一想要的了解"
			intervals [21]:
				xmin = 134.55854
				xmax = 142.20064
				text = "silence"
