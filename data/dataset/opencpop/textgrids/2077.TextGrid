			intervals [29]:
				xmin = 189.18433
				xmax = 196.48754
				text = "那饱满的稻穗幸福了这个季节"
			intervals [30]:
				xmin = 196.48754
				xmax = 202.74476
				text = "而你的脸颊像田里熟透的蕃茄"
			intervals [31]:
				xmin = 202.74476
				xmax = 209.13015
				text = "你突然对我说七里香的名字很美"
			intervals [32]:
