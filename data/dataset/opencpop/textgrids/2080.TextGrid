			intervals [4]:
				xmin = 16.11522
				xmax = 20.06433
				text = "盼我疯魔还盼我孑孓不独活"
			intervals [5]:
				xmin = 20.06433
				xmax = 24.329
				text = "想我冷艳还想我轻佻又下贱"
			intervals [6]:
				xmin = 24.329
				xmax = 28.47239
				text = "要我阳光还要我风情不摇晃"
			intervals [7]:
				xmin = 28.47239
				xmax = 32.56757
				text = "戏我哭笑无主还戏我心如枯木"
			intervals [8]:
				xmin = 32.56757
				xmax = 36.85273
				text = "赐我梦境还赐我很快就清醒"
			intervals [9]:
				xmin = 36.85273
				xmax = 41.02612
				text = "与我沉睡还与我蹉跎无慈悲"
			intervals [10]:
				xmin = 41.02612
