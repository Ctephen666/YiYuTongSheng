			intervals [4]:
				xmin = 17.87622
				xmax = 24.95865
				text = "你降落的太突然了"
			intervals [5]:
				xmin = 24.95865
				xmax = 32.47546
				text = "我刚好呢又路过了"
			intervals [6]:
				xmin = 32.47546
				xmax = 39.00028
				text = "机会难得又主观觉得"
			intervals [7]:
				xmin = 39.00028
				xmax = 46.06374
				text = "想明抢又碰不得"
			intervals [8]:
				xmin = 46.06374
				xmax = 53.21325
				text = "你带来了我的快乐"
			intervals [9]:
				xmin = 53.21325
				xmax = 60.553
				text = "让这世界有点颜色"
			intervals [10]:
				xmin = 60.553
				xmax = 67.40411
				text = "我好想指责你太随意了"
			intervals [11]:
				xmin = 67.40411
				xmax = 70.24911
				text = "宝物该有人"
			intervals [12]:
				xmin = 70.24911
				xmax = 77.37516
				text = "捧着你是不是我的"
			intervals [13]:
				xmin = 77.37516
				xmax = 84.51337
				text = "你像天外来物一样求之不得"
			intervals [14]:
				xmin = 84.51337
				xmax = 91.67606
				text = "你在世俗里的名字不重要了"
			intervals [15]:
				xmin = 91.67606
				xmax = 98.75149
				text = "正好我隐藏的人格是锲而不舍"
			intervals [16]:
				xmin = 98.75149
				xmax = 105.85159
				text = "直到蜂拥而至的人都透明了"
			intervals [17]:
