				text = "简单点"
			intervals [5]:
				xmin = 24.96303
				xmax = 30.32962
				text = "说话的方式简单点"
			intervals [6]:
				xmin = 30.32962
				xmax = 33.57428
				text = "递进的情绪请省略"
			intervals [7]:
				xmin = 33.57428
				xmax = 36.21545
				text = "你又不是个演员"
			intervals [8]:
				xmin = 36.21545
				xmax = 41.94558
				text = "别设计那些情节"
			intervals [9]:
				xmin = 41.94558
				xmax = 46.02884
				text = "没意见"
			intervals [10]:
				xmin = 46.02884
				xmax = 51.58447
				text = "我只想看看你怎么圆"
			intervals [11]:
				xmin = 51.58447
				xmax = 57.2437
				text = "你难过的太表面像没天赋的演员"
			intervals [12]:
				xmin = 57.2437
				xmax = 62.43985
				text = "观众一眼能看见"
			intervals [13]:
				xmin = 62.43985
				xmax = 67.57752
				text = "该配合你演出的我演视而不见"
			intervals [14]:
				xmin = 67.57752
				xmax = 72.82303
				text = "在逼一个最爱你的人即兴表演"
			intervals [15]:
				xmin = 72.82303
				xmax = 78.06705
				text = "什么时候我们开始收起了底线"
			intervals [16]:
				xmin = 78.06705
				xmax = 83.38652
				text = "顺应时代的改变看那些拙劣的表演"
			intervals [17]:
				xmin = 83.38652
				xmax = 88.65826
				text = "可你曾经那么爱我干嘛演出细节"
			intervals [18]:
				xmin = 88.65826
				xmax = 93.83681
				text = "我该变成什么样子才能延缓厌倦"
			intervals [19]:
				xmin = 93.83681
				xmax = 99.31935
				text = "原来当爱放下防备后的这些那些"
			intervals [20]:
				xmin = 99.31935
				xmax = 104.87267
				text = "才是考验"
			intervals [21]:
				xmin = 104.87267
				xmax = 108.83792
				text = "没意见"
			intervals [22]:
				xmin = 108.83792
				xmax = 114.7637
				text = "你想怎样我都随便"
			intervals [23]:
				xmin = 114.7637
				xmax = 117.47539
				text = "你演技也有限"
			intervals [24]:
				xmin = 117.47539
