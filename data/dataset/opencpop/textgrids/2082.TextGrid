				text = "又不用说感言"
			intervals [25]:
				xmin = 119.98862
				xmax = 125.25585
				text = "分开就平淡些"
			intervals [26]:
				xmin = 125.25585
				xmax = 130.54549
				text = "该配合你演出的我演视而不见"
			intervals [27]:
				xmin = 130.54549
				xmax = 135.68678
				text = "别逼一个最爱你的人即兴表演"
			intervals [28]:
				xmin = 135.68678
				xmax = 140.96662
				text = "什么时候我们开始没有了底线"
			intervals [29]:
				xmin = 140.96662
				xmax = 146.31443
				text = "顺着别人的谎言被动就不显得可怜"
			intervals [30]:
