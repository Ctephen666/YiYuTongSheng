				xmax = 16.17942
				text = "silence"
			intervals [4]:
				xmin = 16.17942
				xmax = 23.59565
				text = "你住的巷子里我租了一间公寓"
			intervals [5]:
				xmin = 23.59565
				xmax = 29.29085
				text = "为了想与你不期而遇"
			intervals [6]:
				xmin = 29.29085
				xmax = 36.33721
				text = "高中三年我为什么为什么不好好读书"
			intervals [7]:
				xmin = 36.33721
				xmax = 41.24666
				text = "没考上跟你一样的大学"
			intervals [8]:
				xmin = 41.24666
				xmax = 47.7202
				text = "我找了份工作离你宿舍很近"
			intervals [9]:
				xmin = 47.7202
				xmax = 51.10682
				text = "当我开始学会做蛋饼"
			intervals [10]:
				xmin = 51.10682
				xmax = 55.86844
				text = "才发现你不吃早餐"
			intervals [11]:
				xmin = 55.86844
				xmax = 60.71411
				text = "喔你又擦肩而过"
			intervals [12]:
				xmin = 60.71411
				xmax = 63.94924
				text = "你耳机听什么"
			intervals [13]:
				xmin = 63.94924
				xmax = 68.98351
				text = "能不能告诉我"
			intervals [14]:
				xmin = 68.98351
				xmax = 75.08756
				text = "躺在你学校的操场看星空"
			intervals [15]:
				xmin = 75.08756
				xmax = 81.75485
				text = "教室里的灯还亮着你没走"
			intervals [16]:
				xmin = 81.75485
				xmax = 88.05394
				text = "记得我写给你的情书"
			intervals [17]:
				xmin = 88.05394
				xmax = 91.22417
				text = "都什么年代了"
			intervals [18]:
				xmin = 91.22417
				xmax = 94.8771
				text = "到现在我还在写着"
			intervals [19]:
				xmin = 94.8771
				xmax = 101.0309
				text = "总有一天总有一年会发现"
			intervals [20]:
				xmin = 101.0309
				xmax = 107.67433
				text = "有人默默的陪在你的身边"
			intervals [21]:
				xmin = 107.67433
				xmax = 114.03891
				text = "也许我不该在你的世界"
			intervals [22]:
				xmin = 114.03891
				xmax = 117.44915
				text = "当你收到情书"
			intervals [23]:
				xmin = 117.44915
				xmax = 123.13371
