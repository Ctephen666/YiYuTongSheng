				xmax = 40.18106
				text = "乘着风游荡在蓝天边"
			intervals [7]:
				xmin = 40.18106
				xmax = 45.57344
				text = "一片云掉落在我面前"
			intervals [8]:
				xmin = 45.57344
				xmax = 50.29253
				text = "捏成你的形状随风跟着我"
			intervals [9]:
				xmin = 50.29253
				xmax = 56.33537
				text = "一口一口吃掉忧愁"
			intervals [10]:
				xmin = 56.33537
				xmax = 61.81702
				text = "载着你仿佛载着阳光"
			intervals [11]:
				xmin = 61.81702
				xmax = 67.13425
				text = "不管到哪里都是晴天"
			intervals [12]:
				xmin = 67.13425
				xmax = 71.88904
