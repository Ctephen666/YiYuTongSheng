			intervals [5]:
				xmin = 21.17315
				xmax = 26.94714
				text = "总是忍不住寂寞掉下眼泪"
			intervals [6]:
				xmin = 26.94714
				xmax = 29.8907
				text = "你才会给安慰"
			intervals [7]:
				xmin = 29.8907
				xmax = 35.75638
				text = "担心短暂的晴天随时都可能"
			intervals [8]:
				xmin = 35.75638
				xmax = 38.484
				text = "被阴霾收回"
			intervals [9]:
				xmin = 38.484
				xmax = 44.08688
				text = "等待有机会最坏也最甜美"
			intervals [10]:
				xmin = 44.08688
				xmax = 46.98824
				text = "我乐观却疲惫"
			intervals [11]:
				xmin = 46.98824
				xmax = 49.85835
				text = "因为太怕失去你"
			intervals [12]:
				xmin = 49.85835
				xmax = 56.49404
				text = "所以连快乐里都装满伤悲"
			intervals [13]:
				xmin = 56.49404
				xmax = 59.11393
				text = "你不曾发觉"
			intervals [14]:
				xmin = 59.11393
				xmax = 63.10797
				text = "你总是用右手牵着我"
			intervals [15]:
				xmin = 63.10797
				xmax = 67.67568
				text = "但是心却跳动在左边"
			intervals [16]:
				xmin = 67.67568
				xmax = 70.3482
				text = "你和我之间的遥远"
			intervals [17]:
				xmin = 70.3482
				xmax = 72.4869
				text = "永远隔着亲切"
			intervals [18]:
				xmin = 72.4869
				xmax = 76.70583
				text = "爱少的可怜伸出右手"
			intervals [19]:
				xmin = 76.70583
				xmax = 80.2358
				text = "想陪着你向前走"
			intervals [20]:
				xmin = 80.2358
				xmax = 84.8075
				text = "感受你爱我的心跳在左边"
			intervals [21]:
				xmin = 84.8075
