			intervals [5]:
				xmin = 29.19524
				xmax = 32.63986
				text = "故事的小黄花"
			intervals [6]:
				xmin = 32.63986
				xmax = 36.21128
				text = "从出生那年就飘着"
			intervals [7]:
				xmin = 36.21128
				xmax = 39.60887
				text = "童年的荡秋千"
			intervals [8]:
				xmin = 39.60887
				xmax = 41.74456
				text = "随记忆一直晃"
			intervals [9]:
				xmin = 41.74456
				xmax = 49.68732
				text = "到现在"
			intervals [10]:
				xmin = 49.68732
				xmax = 53.04185
				text = "吹着前奏望着天空"
			intervals [11]:
				xmin = 53.04185
				xmax = 56.63479
				text = "我想起花瓣试着掉落"
			intervals [12]:
				xmin = 56.63479
				xmax = 58.78757
				text = "为你翘课的那一天"
			intervals [13]:
				xmin = 58.78757
				xmax = 62.31684
				text = "花落的那一天教室的那一间"
			intervals [14]:
				xmin = 62.31684
				xmax = 65.81337
				text = "我怎么看不见消失的下雨天"
			intervals [15]:
				xmin = 65.81337
				xmax = 69.81745
				text = "我好想再淋一遍"
			intervals [16]:
				xmin = 69.81745
				xmax = 76.06647
				text = "没想到失去的勇气我还留着"
			intervals [17]:
				xmin = 76.06647
				xmax = 79.54945
				text = "好想再问一遍你会等待"
			intervals [18]:
				xmin = 79.54945
				xmax = 84.8707
				text = "还是离开"
			intervals [19]:
				xmin = 84.8707
				xmax = 90.48615
