			intervals [5]:
				xmin = 26.08497
				xmax = 30.68744
				text = "素胚勾勒出青花笔锋浓转淡"
			intervals [6]:
				xmin = 30.68744
				xmax = 35.10819
				text = "瓶身描绘的牡丹一如你初妆"
			intervals [7]:
				xmin = 35.10819
				xmax = 39.56947
				text = "冉冉檀香透过窗心事我了然"
			intervals [8]:
				xmin = 39.56947
				xmax = 43.94867
				text = "宣纸上走笔至此搁一半"
			intervals [9]:
				xmin = 43.94867
				xmax = 48.51665
				text = "釉色渲染仕女图韵味被私藏"
			intervals [10]:
				xmin = 48.51665
				xmax = 52.90612
				text = "而你嫣然的一笑如含苞待放"
			intervals [11]:
				xmin = 52.90612
				xmax = 55.33672
				text = "你的美一缕飘散"
			intervals [12]:
				xmin = 55.33672
				xmax = 61.81025
				text = "去到我去不了的地方"
			intervals [13]:
				xmin = 61.81025
				xmax = 66.19823
				text = "天青色等烟雨而我在等你"
			intervals [14]:
				xmin = 66.19823
				xmax = 70.66074
				text = "炊烟袅袅升起隔江千万里"
			intervals [15]:
				xmin = 70.66074
				xmax = 75.07877
				text = "在瓶底书汉隶仿前朝的飘逸"
			intervals [16]:
				xmin = 75.07877
				xmax = 79.60635
				text = "就当我为遇见你伏笔"
			intervals [17]:
				xmin = 79.60635
				xmax = 84.02676
				text = "天青色等烟雨而我在等你"
			intervals [18]:
