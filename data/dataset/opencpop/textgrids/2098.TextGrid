				xmax = 49.79647
				text = "修炼爱情的心酸"
			intervals [12]:
				xmin = 49.79647
				xmax = 53.91719
				text = "学会放好以前的渴望"
			intervals [13]:
				xmin = 53.91719
				xmax = 60.53542
				text = "我们那些信仰要忘记多难"
			intervals [14]:
				xmin = 60.53542
