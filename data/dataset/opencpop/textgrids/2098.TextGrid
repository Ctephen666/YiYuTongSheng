			intervals [7]:
				xmin = 29.0657
				xmax = 31.3028
				text = "往事不会说谎"
			intervals [8]:
				xmin = 31.3028
				xmax = 36.07212
				text = "别跟它为难"
			intervals [9]:
				xmin = 36.07212
