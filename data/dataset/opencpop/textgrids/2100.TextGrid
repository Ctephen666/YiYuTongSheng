	item [1]:
		class = "IntervalTier"
		name = "句子"
		xmin = 0.0
		xmax = 237.07202
		intervals: size = 55
			intervals [1]:
				xmin = 0.0
				xmax = 3.7867
				text = "silence"
			intervals [2]:
				xmin = 3.7867
				xmax = 8.5417
				text = "silence"
			intervals [3]:
				xmin = 8.5417
				xmax = 16.52055
				text = "silence"
			intervals [4]:
				xmin = 16.52055
				xmax = 20.09573
				text = "醒来灿烂星光透过了窗台"
			intervals [5]:
				xmin = 20.09573
				xmax = 23.91214
				text = "海岸线连接了那片山川大海"
			intervals [6]:
				xmin = 23.91214
				xmax = 27.84694
				text = "涌动梦境边缘像是空旷舞台"
			intervals [7]:
				xmin = 27.84694
				xmax = 31.51536
				text = "在这忽然展开"
			intervals [8]:
				xmin = 31.51536
				xmax = 35.39168
				text = "虚拟世界看银河慢慢散开"
			intervals [9]:
				xmin = 35.39168
				xmax = 39.07647
				text = "我听见有微风轻轻拂去阴霾"
			intervals [10]:
				xmin = 39.07647
				xmax = 42.83686
				text = "期待却不知未来如何安排"
			intervals [11]:
				xmin = 42.83686
				xmax = 45.2423
				text = "将故事勇敢翻开"
			intervals [12]:
				xmin = 45.2423
				xmax = 48.93391
				text = "不要再沉默徘徊"
			intervals [13]:
				xmin = 48.93391
				xmax = 52.70234
				text = "我知道生活有着太多无奈"
			intervals [14]:
				xmin = 52.70234
				xmax = 56.41535
				text = "冲破这层层阻碍"
			intervals [15]:
				xmin = 56.41535
				xmax = 60.41313
				text = "走吧没人能让你停下来"
			intervals [16]:
				xmin = 60.41313
				xmax = 63.96526
				text = "我想我早开始感受着释怀"
			intervals [17]:
				xmin = 63.96526
				xmax = 67.73113
				text = "我才明白外面世界如此精彩"
			intervals [18]:
				xmin = 67.73113
				xmax = 71.33991
				text = "我已知晓未来也不须再等待"
			intervals [19]:
				xmin = 71.33991
				xmax = 75.45207
				text = "时间飞这生命似钟摆"
			intervals [20]:
				xmin = 75.45207
				xmax = 78.89466
				text = "就算曾经我们都轻如尘埃"
			intervals [21]:
				xmin = 78.89466
				xmax = 82.6561
				text = "像幻梦落入了拟人的花海"
			intervals [22]:
				xmin = 82.6561
				xmax = 86.36312
				text = "是你让我对世界充满着热爱"
			intervals [23]:
				xmin = 86.36312
				xmax = 92.8065
				text = "相信我破晓会跨山海准时到来
"
			intervals [24]:
				xmin = 92.8065
				xmax = 99.44162
				text = "silence"
			intervals [25]:
				xmin = 99.44162
				xmax = 106.58771
				text = "silence"
			intervals [26]:
				xmin = 106.58771
				xmax = 110.3608
				text = "这世界是否看到我的未来"
			intervals [27]:
				xmin = 110.3608
				xmax = 114.09632
				text = "真实的你请把虚拟的门打开"
			intervals [28]:
				xmin = 114.09632
				xmax = 117.88089
				text = "黎明中谁为我创造了舞台"
			intervals [29]:
				xmin = 117.88089
				xmax = 120.19286
				text = "这是另一个未来"
			intervals [30]:
				xmin = 120.19286
				xmax = 123.96111
				text = "这属于我的时代"
			intervals [31]:
				xmin = 123.96111
				xmax = 127.69205
				text = "它终将为我们彼此而喝彩"
			intervals [32]:
				xmin = 127.69205
				xmax = 131.37035
				text = "歌声散落九天外"
			intervals [33]:
				xmin = 131.37035
				xmax = 135.44121
				text = "世界从此不会平庸黯淡"
			intervals [34]:
				xmin = 135.44121
				xmax = 138.98884
				text = "给我一双翅膀定能向大海"
			intervals [35]:
				xmin = 138.98884
				xmax = 142.7142
				text = "哪怕再小的恐惧和再大的阻碍"
			intervals [36]:
