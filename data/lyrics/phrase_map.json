{
  "source": "opencpop_textgrid",
  "sample_id": "2001",
  "textgrid": "data\\dataset\\opencpop\\textgrids\\2001.TextGrid",
  "note_index_rule": "note_start inclusive, note_end exclusive",
  "phrases": [
    {
      "id": 1,
      "zh": "感受停在我发端的指尖",
      "start": 12.47841,
      "end": 16.55634,
      "note_start": 0,
      "note_end": 10
    },
    {
      "id": 2,
      "zh": "如何瞬间冻结时间",
      "start": 16.55634,
      "end": 23.33113,
      "note_start": 10,
      "note_end": 18
    },
    {
      "id": 3,
      "zh": "记住望着我坚定的双眼",
      "start": 23.33113,
      "end": 27.46611,
      "note_start": 18,
      "note_end": 28
    },
    {
      "id": 4,
      "zh": "也许已经没有明天",
      "start": 27.46611,
      "end": 33.97518,
      "note_start": 28,
      "note_end": 36
    },
    {
      "id": 5,
      "zh": "面对浩瀚的星海我们微小得像尘埃",
      "start": 33.97518,
      "end": 39.06457,
      "note_start": 36,
      "note_end": 56
    },
    {
      "id": 6,
      "zh": "漂浮在一片无奈",
      "start": 39.06457,
      "end": 44.8147,
      "note_start": 56,
      "note_end": 68
    },
    {
      "id": 7,
      "zh": "缘份让我们相遇乱世以外",
      "start": 44.8147,
      "end": 50.3095,
      "note_start": 68,
      "note_end": 79
    },
    {
      "id": 8,
      "zh": "命运却要我们危难中相爱",
      "start": 50.3095,
      "end": 55.7377,
      "note_start": 79,
      "note_end": 90
    },
    {
      "id": 9,
      "zh": "也许未来遥远在光年之外",
      "start": 55.7377,
      "end": 61.18378,
      "note_start": 90,
      "note_end": 101
    },
    {
      "id": 10,
      "zh": "我愿守候未知里为你等待",
      "start": 61.18378,
      "end": 65.19451,
      "note_start": 101,
      "note_end": 112
    },
    {
      "id": 11,
      "zh": "我没想到为了你我能疯狂到山崩海啸",
      "start": 65.19451,
      "end": 72.03509,
      "note_start": 112,
      "note_end": 128
    },
    {
      "id": 12,
      "zh": "没有你根本不想逃我的大脑",
      "start": 72.03509,
      "end": 77.57073,
      "note_start": 128,
      "note_end": 141
    },
    {
      "id": 13,
      "zh": "为了你已经疯狂到脉搏心跳没有你",
      "start": 77.57073,
      "end": 83.74217,
      "note_start": 141,
      "note_end": 156
    },
    {
      "id": 14,
      "zh": "根本不重要",
      "start": 83.74217,
      "end": 88.81514,
      "note_start": 156,
      "note_end": 161
    },
    {
      "id": 15,
      "zh": "一双围在我胸口的臂弯",
      "start": 88.81514,
      "end": 92.82762,
      "note_start": 161,
      "note_end": 171
    },
    {
      "id": 16,
      "zh": "足够抵挡天旋地转",
      "start": 92.82762,
      "end": 99.7639,
      "note_start": 171,
      "note_end": 179
    },
    {
      "id": 17,
      "zh": "一种执迷不放手的倔强足以",
      "start": 99.7639,
      "end": 104.54605,
      "note_start": 179,
      "note_end": 193
    },
    {
      "id": 18,
      "zh": "点燃所有希望",
      "start": 104.54605,
      "end": 110.2519,
      "note_start": 193,
      "note_end": 200
    },
    {
      "id": 19,
      "zh": "宇宙磅礡而冷漠我们的爱微小却闪烁",
      "start": 110.2519,
      "end": 115.4605,
      "note_start": 200,
      "note_end": 222
    },
    {
      "id": 20,
      "zh": "颠簸却如此忘我",
      "start": 115.4605,
      "end": 121.18199,
      "note_start": 222,
      "note_end": 233
    },
    {
      "id": 21,
      "zh": "缘分让我们相遇乱世以外",
      "start": 121.18199,
      "end": 126.68117,
      "note_start": 233,
      "note_end": 244
    },
    {
      "id": 22,
      "zh": "命运却要我们危难中相爱",
      "start": 126.68117,
      "end": 132.10616,
      "note_start": 244,
      "note_end": 255
    },
    {
      "id": 23,
      "zh": "也许未来遥远在光年之外",
      "start": 132.10616,
      "end": 137.541,
      "note_start": 255,
      "note_end": 266
    },
    {
      "id": 24,
      "zh": "我愿守候未知里为你等待",
      "start": 137.541,
      "end": 141.559,
      "note_start": 266,
      "note_end": 277
    },
    {
      "id": 25,
      "zh": "我没想到为了你我能疯狂到",
      "start": 141.559,
      "end": 146.99698,
      "note_start": 277,
      "note_end": 289
    },
    {
      "id": 26,
      "zh": "山崩海啸没有你根本不想逃",
      "start": 146.99698,
      "end": 152.53254,
      "note_start": 289,
      "note_end": 301
    },
    {
      "id": 27,
      "zh": "我的大脑为了你已经疯狂到",
      "start": 152.53254,
      "end": 157.93827,
      "note_start": 301,
      "note_end": 313
    },
    {
      "id": 28,
      "zh": "脉搏心跳没有你根本不重",
      "start": 157.93827,
      "end": 161.78984,
      "note_start": 313,
      "note_end": 324
    },
    {
      "id": 29,
      "zh": "要也许航道以外",
      "start": 161.78984,
      "end": 169.54354,
      "note_start": 324,
      "note_end": 332
    },
    {
      "id": 30,
      "zh": "是醒不来的梦乱世",
      "start": 169.54354,
      "end": 177.44916,
      "note_start": 332,
      "note_end": 340
    },
    {
      "id": 31,
      "zh": "以外是纯粹的相拥",
      "start": 177.44916,
      "end": 185.21924,
      "note_start": 340,
      "note_end": 349
    },
    {
      "id": 32,
      "zh": "我没想到为了你我能疯狂到山崩海啸",
      "start": 185.21924,
      "end": 192.08807,
      "note_start": 349,
      "note_end": 365
    },
    {
      "id": 33,
      "zh": "没有你根本不想逃我的大脑为了你已经疯狂",
      "start": 192.08807,
      "end": 200.02843,
      "note_start": 365,
      "note_end": 384
    },
    {
      "id": 34,
      "zh": "到脉搏心跳没有你根本不重要",
      "start": 200.02843,
      "end": 207.32931,
      "note_start": 384,
      "note_end": 397
    },
    {
      "id": 35,
      "zh": "相遇乱世以外",
      "start": 207.32931,
      "end": 212.88081,
      "note_start": 397,
      "note_end": 404
    },
    {
      "id": 36,
      "zh": "危难中相爱相遇",
      "start": 212.88081,
      "end": 219.11413,
      "note_start": 404,
      "note_end": 413
    },
    {
      "id": 37,
      "zh": "乱世以外危难中",
      "start": 219.11413,
      "end": 226.80215,
      "note_start": 413,
      "note_end": 421
    },
    {
      "id": 38,
      "zh": "相爱我没想到",
      "start": 226.80215,
      "end": 230.49141,
      "note_start": 421,
      "note_end": 429
    }
  ]
}